{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    }
  },
  "mcpServers": {
    "burp": {
      "command": "/bin/bash",
      "args": ["/Users/user/ai_config/burp-mcp/start-burp-mcp.sh"],
      "timeout": 30000,
      "trust": false
    }
  }
}
